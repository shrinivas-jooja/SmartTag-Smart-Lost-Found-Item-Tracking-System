# public

# vuepress build output
.vuepress/dist

# Serverless Webpack templates
.webpack/

# Service Answer Image (Vite)
dist-ssr
*.local

# DynamoDB Local files
.dynamodb/

# Tern transient files
.tern-port

# shellcheck-sarif cache
.shellcheck-sarif

